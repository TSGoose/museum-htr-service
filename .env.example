APP_NAME=museum-ocr-service
APP_ENV=local
APP_VERSION=0.2.0
API_V1_PREFIX=/api/v1

POSTGRES_HOST=ocr-postgres
POSTGRES_PORT=5432
POSTGRES_DB=museum_ocr
POSTGRES_USER=museum_ocr
POSTGRES_PASSWORD=museum_ocr

REDIS_URL=redis://ocr-redis:6379/0

DATA_DIR=/app/data
UPLOADS_DIR=/app/data/uploads
TRAINING_DIR=/app/data/training
MODELS_DIR=/app/models
LOGS_DIR=/app/logs

OCR_UPLOADS_MAX_FILES=500
OCR_KEEP_CORRECTED_IMAGES=true
OCR_SAVE_LINE_CROPS=true
OCR_SAVE_TECHNICAL_JSON=true

# Safe default for local infrastructure tests.
# For real OCR switch to:
# OCR_PIPELINE=kraken-segmentation-transformers-trocr
# OCR_SEGMENTER=kraken
# OCR_RECOGNIZER=transformers_trocr
OCR_PIPELINE=dummy
OCR_PREPROCESSING_ENABLED=true
OCR_DESKEW_ENABLED=true
OCR_BINARIZATION_ENABLED=false
OCR_MAX_IMAGE_SIDE=3000

OCR_SEGMENTER=dummy
OCR_SIMPLE_SEGMENTER_MIN_LINE_HEIGHT=16
OCR_SIMPLE_SEGMENTER_MIN_INK_RATIO=0.005
OCR_KRAKEN_SEGMENTATION_MODEL_PATH=/app/models/kraken/segmentation/blla.mlmodel

OCR_RECOGNIZER=dummy
OCR_TROCR_MODEL_NAME=Kansallisarkisto/cyrillic-htr-model
OCR_TROCR_MODEL_PATH=/app/models/huggingface/Kansallisarkisto/cyrillic-htr-model
OCR_TROCR_DEVICE=cpu
OCR_TROCR_MAX_NEW_TOKENS=256

OCR_FALLBACK_RECOGNIZER=dummy
OCR_FALLBACK_MODEL_NAME=raxtemur/trocr-base-ru

OCR_JOB_MAX_RETRIES=3
OCR_JOB_TIMEOUT_SECONDS=300
OCR_WORKER_CONCURRENCY=1

LOG_LEVEL=INFO
LOG_FORMAT=json
